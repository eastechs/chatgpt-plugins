{
  "name": "myapp",
  "productName": "MyApp",
  "version": "0.1.0",
  "private": true,
  "description": "An Electron + Express + Vite + React Router app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:main\" \"npm run dev:electron\"",
    "dev:vite": "vite --config vite.config.ts",
    "dev:main": "tsup --watch",
    "dev:electron": "node scripts/wait-for-vite.js && node scripts/launch-electron.js",
    "start": "node scripts/launch-electron.js",
    "build": "tsup && vite build --config vite.config.ts",
    "build:all": "npm run build && electron-builder",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vite": "^7.0.4"
  }
}
